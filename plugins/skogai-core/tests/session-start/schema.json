{
  "name": "session-start",
  "description": "SessionStart hook — bootstrap env, inject LESSON_DIRS and PATH context",
  "examples": [
    {
      "description": "source startup injects Bootstrap complete",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","cwd":"/tmp/test-project","permission_mode":"default","source":"startup"},
      "output": {"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"Bootstrap complete."}}
    },
    {
      "description": "source resume injects Bootstrap complete",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","cwd":"/tmp/test-project","permission_mode":"default","source":"resume"},
      "output": {"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"Bootstrap complete."}}
    },
    {
      "description": "source compact injects Bootstrap complete",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","cwd":"/tmp/test-project","permission_mode":"default","source":"compact"},
      "output": {"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"Bootstrap complete."}}
    },
    {
      "description": "cwd is injected into LESSON_DIRS",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","cwd":"/tmp/test-project","permission_mode":"default","source":"startup"},
      "output": {"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"LESSON_DIRS=/tmp/test-project/tests/lessons"}}
    },
    {
      "description": "cwd is injected into PATH includes",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","cwd":"/tmp/test-project","permission_mode":"default","source":"startup"},
      "output": {"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"PATH includes /tmp/test-project/.skogai/tmp/bin"}}
    },
    {
      "description": "missing cwd uses UNKNOWN_CWD sentinel in LESSON_DIRS",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","permission_mode":"default","source":"startup"},
      "output": {"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"LESSON_DIRS=UNKNOWN_CWD/tests/lessons"}}
    },
    {
      "description": "missing cwd uses UNKNOWN_CWD sentinel in PATH",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","permission_mode":"default","source":"startup"},
      "output": {"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"PATH includes UNKNOWN_CWD/.skogai/tmp/bin"}}
    },
    {
      "description": "log entry is written to session log file",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","cwd":"/tmp/test-project","permission_mode":"default","source":"startup"},
      "output": {"log_exists": true}
    },
    {
      "description": "log entry contains env block",
      "input": {"session_id":"test-ss-session","hook_event_name":"SessionStart","cwd":"/tmp/test-project","permission_mode":"default","source":"startup"},
      "output": {"log_env_not_null": true}
    }
  ]
}
