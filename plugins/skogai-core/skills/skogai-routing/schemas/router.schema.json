{
  "$id": "https://skog.ai/schemas/router.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    { "$ref": "document.schema.json" },
    {
      "properties": {
        "type": { "const": "router" },
        "sections": {
          "type": "array",
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": {
                  "name": { "const": "objective" }
                },
                "required": ["name"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "name": { "const": "routing" }
                },
                "required": ["name"]
              }
            }
          ]
        }
      },
      "required": ["type", "sections"]
    }
  ]
}
