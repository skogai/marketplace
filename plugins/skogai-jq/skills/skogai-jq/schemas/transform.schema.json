{
  "$id": "https://skog.ai/schemas/transform.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "skogai-jq transform schema.json",
  "type": "object",
  "required": ["name", "description", "version", "input", "args", "output", "examples", "tags"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "input": {
      "$ref": "#/$defs/ioSpec"
    },
    "args": {
      "type": "object",
      "description": "Argument definitions keyed by CLI arg name",
      "additionalProperties": {
        "$ref": "#/$defs/argSpec"
      }
    },
    "output": {
      "$ref": "#/$defs/ioSpec"
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/exampleSpec"
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "jsonType": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "object", "array", "null"]
        },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["string", "number", "integer", "boolean", "object", "array", "null"]
          }
        }
      ]
    },
    "ioSpec": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {
          "$ref": "#/$defs/jsonType"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "argSpec": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {
          "$ref": "#/$defs/jsonType"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "exampleSpec": {
      "type": "object",
      "required": ["description", "input", "args", "output"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "input": {},
        "args": {
          "type": "object"
        },
        "output": {}
      },
      "additionalProperties": false
    }
  }
}
