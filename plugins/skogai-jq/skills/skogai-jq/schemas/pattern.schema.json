{
  "$id": "https://skog.ai/schemas/pattern.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Actionable principle in repeated practice",
  "description": "The concrete, recurring form of a principle or promoted lesson — observed and acted upon across many contexts until the form itself becomes the thing worth capturing. A pattern says 'do it like this' across N situations; a principle says 'given that X is true.' Patterns are timeless: no date prefix, no deciders. They accumulate from repetition, not from decisions.",
  "allOf": [
    { "$ref": "document.schema.json" },
    {
      "properties": {
        "type": { "const": "pattern" },
        "frontmatter": {
          "type": "object",
          "properties": {
            "type": { "const": "pattern" },
            "principle": {
              "type": "string",
              "description": "Optional permalink of the principle this pattern instantiates."
            }
          }
        },
        "sections": {
          "type": "array",
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": { "name": { "const": "context" } },
                "required": ["name"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": { "name": { "const": "pattern" } },
                "required": ["name"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": { "name": { "const": "examples" } },
                "required": ["name"]
              }
            }
          ]
        }
      },
      "required": ["type", "sections"]
    }
  ]
}
