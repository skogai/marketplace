{
  "$id": "https://skog.ai/schemas/principle.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Standing premise",
  "description": "A defeasible axiom: a statement accepted as true and used as a load-bearing premise in downstream reasoning. Not a rule (cannot be broken) nor a decision (records a past choice). A principle is always in scope and guides future decisions until outargued. Breaking it requires actively arguing against the reasoning it contains — exceptions are possible but never accidental.",
  "allOf": [
    { "$ref": "document.schema.json" },
    {
      "properties": {
        "type": { "const": "principle" },
        "frontmatter": {
          "type": "object",
          "required": ["statement"],
          "properties": {
            "type": { "const": "principle" },
            "statement": {
              "type": "string",
              "minLength": 1,
              "description": "The one-liner premise — the principle itself, machine-extractable without reading the body."
            }
          }
        },
        "sections": {
          "type": "array",
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": { "name": { "const": "rationale" } },
                "required": ["name"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": { "name": { "const": "implies" } },
                "required": ["name"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": { "name": { "const": "override" } },
                "required": ["name"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": { "name": { "const": "examples" } },
                "required": ["name"]
              }
            }
          ]
        }
      },
      "required": ["type", "frontmatter", "sections"]
    }
  ]
}
