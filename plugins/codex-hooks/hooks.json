{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/log-event.sh",
            "timeout": 5,
            "statusMessage": "Logging Codex session start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/log-event.sh",
            "timeout": 5,
            "statusMessage": "Logging Codex prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/log-event.sh",
            "timeout": 5,
            "statusMessage": "Logging Codex tool preflight"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/log-event.sh",
            "timeout": 5,
            "statusMessage": "Logging Codex permission request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/log-event.sh",
            "timeout": 5,
            "statusMessage": "Logging Codex tool completion"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/log-event.sh",
            "timeout": 5,
            "statusMessage": "Logging Codex stop"
          }
        ]
      }
    ]
  }
}
