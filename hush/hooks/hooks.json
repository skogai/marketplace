{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|PowerShell)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/preserve-exit-code.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\preserve-exit-code.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/silence-nudge.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\silence-nudge.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/subagent-brief.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\subagent-brief.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/precompact-summary.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\precompact-summary.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/postcompact-rearm.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\postcompact-rearm.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|PowerShell|Read|Grep|mcp__.+__(get_file_problems|search_regex|search_in_files_by_text|search_in_files_by_regex|build_project|get_run_configurations|search_text|execute_run_configuration|execute_terminal_command))$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/compress-tool-output.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\compress-tool-output.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/narration-meter.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\narration-meter.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/silence-nudge.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\silence-nudge.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
