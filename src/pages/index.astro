---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORY_ICONS } from '../data/categoryIcons';
---
<BaseLayout title="Claude Code Repos Index">


<header class="hero">
  <div class="hero-inner">
    <img src="/banner.png" alt="Claude Code Projects" class="hero-banner" />
    <p>A curated collection of <span id="repo-count">100+</span> repositories exploring Claude Code beyond traditional development &mdash; from sysadmin workspaces to legal research, health tracking, and more.</p>
    <p style="margin-top: 0.75rem;"><a href="https://github.com/danielrosehill/Claude-Agent-Workspace-Model" target="_blank" rel="noopener" style="color: #c4b5fd; font-weight: 500;">The Agent Workspace Model &rarr;</a> <span style="opacity: 0.7; margin-left: 0.25rem;">The template behind these workspaces</span></p>
    <div class="hero-stats">
      <div class="stat"><span class="stat-num" id="stat-repos">-</span><span class="stat-label">Repositories</span></div>
      <div class="stat"><span class="stat-num" id="stat-tags">-</span><span class="stat-label">Tags</span></div>
      <div class="stat"><span class="stat-num" id="stat-cats">-</span><span class="stat-label">Categories</span></div>
    </div>
  </div>
</header>

<div class="toolbar">
  <div class="toolbar-inner">
    <input type="text" class="search-box" id="search" placeholder="Search repositories..." autocomplete="off">
    <div class="sort-toggle">
      <button class="sort-btn active" id="sort-newest" onclick="setSort('newest')">Newest</button>
      <button class="sort-btn" id="sort-az" onclick="setSort('az')">A&ndash;Z</button>
    </div>
    <div class="result-count" id="result-count"></div>
  </div>
</div>

<div class="breadcrumbs" id="breadcrumbs" style="display:none">
  <div class="breadcrumbs-inner">
    <a href="/">Index</a>
    <span class="bc-sep">/</span>
    <span class="bc-current" id="bc-label"></span>
    <button class="bc-clear" onclick="clearFilters()" title="Clear filter">&times;</button>
  </div>
</div>

<main class="content">
  <aside class="sidebar" id="sidebar">
    <h3 class="sidebar-heading">Categories</h3>
    <div id="category-nav"></div>
    <div class="sidebar-section">
      <h3 class="sidebar-heading">Tags</h3>
      <div id="tag-list"></div>
    </div>
    <div class="sidebar-section">
      <h3 class="sidebar-heading">Data</h3>
      <a class="sidebar-link" href="https://github.com/danielrosehill/Claude-Code-Repos-Index" target="_blank">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Source Repository
      </a>
      <a class="sidebar-link" href="/tagged_repos.json" target="_blank">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 1h8l3 3v11H1V1h3z"/><path d="M5 8h6M5 11h4"/></svg>
        JSON Data
      </a>
    </div>
  </aside>

  <div class="repo-area" id="repo-area">
    <div class="loading">Loading repositories...</div>
  </div>
</main>

<script define:vars={{ CATEGORY_ICONS }}>
let repos = [];
let allTags = [];
let catHierarchy = null;
let activeTags = new Set();
let activeCategory = '';
let searchQuery = '';
let sortMode = 'newest';
const PAGE_SIZE = 10;
let currentPage = 1;

async function loadData() {
  try {
    const [repoRes, catRes] = await Promise.all([
      fetch('/tagged_repos.json'),
      fetch('/categories.json')
    ]);
    repos = await repoRes.json();
    catHierarchy = await catRes.json();

    const tagCount = {};
    repos.forEach(r => r.tags.forEach(t => { tagCount[t] = (tagCount[t] || 0) + 1; }));
    allTags = Object.entries(tagCount).sort((a, b) => a[0].localeCompare(b[0]));

    const uniqueCats = new Set(repos.map(r => r.category));

    document.getElementById('stat-repos').textContent = repos.length;
    document.getElementById('repo-count').textContent = repos.length;
    document.getElementById('stat-tags').textContent = allTags.length;
    document.getElementById('stat-cats').textContent = uniqueCats.size;

    buildCategoryNav();
    buildTagList();

    const params = new URLSearchParams(window.location.search);
    if (params.get('category')) {
      activeCategory = params.get('category');
      updateCategoryButtons();
    }
    if (params.get('tag')) {
      activeTags.add(params.get('tag'));
      updateTagButtons();
    }

    render();

    document.getElementById('search').addEventListener('input', e => {
      searchQuery = e.target.value.toLowerCase().trim();
      currentPage = 1;
      render();
    });
  } catch (e) {
    document.getElementById('repo-area').innerHTML = '<div class="loading">Failed to load data.</div>';
  }
}

function buildCategoryNav() {
  const container = document.getElementById('category-nav');
  catHierarchy.groups.forEach(group => {
    const groupEl = document.createElement('div');
    groupEl.className = 'cat-group';
    const groupLabel = document.createElement('div');
    groupLabel.className = 'cat-group-label';
    groupLabel.innerHTML = (CATEGORY_ICONS[group.name] || '') + ' ' + esc(group.name);
    groupEl.appendChild(groupLabel);

    group.categories.forEach(cat => {
      const count = repos.filter(r => r.category_slug === cat.slug).length;
      if (count === 0) return;
      const btn = document.createElement('button');
      btn.className = 'cat-btn';
      btn.dataset.slug = cat.slug;
      btn.innerHTML = (CATEGORY_ICONS[cat.name] || '') + ' <span class="cat-name">' + esc(cat.name) + '</span><span class="tag-count">' + count + '</span>';
      btn.onclick = () => {
        activeCategory = activeCategory === cat.slug ? '' : cat.slug;
        currentPage = 1;
        updateCategoryButtons();
        render();
        updateURL();
      };
      groupEl.appendChild(btn);
    });
    container.appendChild(groupEl);
  });
}

function updateCategoryButtons() {
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.classList.toggle('active', activeCategory === btn.dataset.slug);
  });
}

function buildTagList() {
  const container = document.getElementById('tag-list');
  allTags.forEach(([tag, count]) => {
    const btn = document.createElement('button');
    btn.className = 'tag-btn';
    btn.innerHTML = '<span class="tag-name">' + esc(tag) + '</span><span class="tag-count">' + count + '</span>';
    btn.onclick = () => {
      if (activeTags.has(tag)) activeTags.delete(tag);
      else activeTags.add(tag);
      currentPage = 1;
      updateTagButtons();
      render();
      updateURL();
    };
    btn.dataset.tag = tag;
    container.appendChild(btn);
  });
}

function updateTagButtons() {
  document.querySelectorAll('.tag-btn').forEach(btn => {
    if (btn.dataset.tag) btn.classList.toggle('active', activeTags.has(btn.dataset.tag));
  });
}

function updateURL() {
  const params = new URLSearchParams();
  if (activeCategory) params.set('category', activeCategory);
  if (activeTags.size === 1) params.set('tag', [...activeTags][0]);
  const qs = params.toString();
  history.replaceState(null, '', qs ? '?' + qs : window.location.pathname);
}

window.clearFilters = function() {
  activeCategory = '';
  activeTags.clear();
  searchQuery = '';
  currentPage = 1;
  document.getElementById('search').value = '';
  updateCategoryButtons();
  updateTagButtons();
  render();
  updateURL();
}

function render() {
  const area = document.getElementById('repo-area');
  const bc = document.getElementById('breadcrumbs');
  const bcLabel = document.getElementById('bc-label');

  const filtered = repos.filter(r => {
    if (activeCategory && r.category_slug !== activeCategory) return false;
    if (activeTags.size > 0 && ![...activeTags].some(t => r.tags.includes(t))) return false;
    if (searchQuery) {
      return r.name.toLowerCase().includes(searchQuery) ||
             r.description.toLowerCase().includes(searchQuery) ||
             r.tags.some(t => t.toLowerCase().includes(searchQuery)) ||
             r.category.toLowerCase().includes(searchQuery);
    }
    return true;
  });

  if (activeCategory || activeTags.size > 0) {
    bc.style.display = '';
    const labels = [];
    if (activeCategory) {
      const catRepo = repos.find(r => r.category_slug === activeCategory);
      labels.push(catRepo ? catRepo.category : activeCategory);
    }
    activeTags.forEach(t => labels.push('Tag: ' + t));
    bcLabel.textContent = labels.join(' + ');
  } else {
    bc.style.display = 'none';
  }

  if (sortMode === 'newest') {
    filtered.sort((a, b) => (b.created_date || '').localeCompare(a.created_date || '') || a.name.localeCompare(b.name));
  } else {
    filtered.sort((a, b) => a.name.localeCompare(b.name));
  }

  const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
  if (currentPage > totalPages) currentPage = totalPages;
  const start = (currentPage - 1) * PAGE_SIZE;
  const pageRepos = filtered.slice(start, start + PAGE_SIZE);

  const countEl = document.getElementById('result-count');
  if (searchQuery || activeTags.size > 0 || activeCategory) {
    countEl.textContent = filtered.length + ' of ' + repos.length + ' repos';
  } else {
    countEl.textContent = repos.length + ' repos';
  }

  if (filtered.length === 0) {
    area.innerHTML = '<div class="loading">No repositories match your filters.</div>';
    return;
  }

  let html = '<div class="repo-grid">';
  pageRepos.forEach(repo => {
    const detailUrl = '/repos/' + esc(repo.slug) + '/';
    const dateLabel = repo.created_date ? '<span class="repo-card-date">Created ' + esc(repo.created_date) + '</span>' : '';
    html += '<div class="repo-card">' +
      '<div class="repo-header">' +
        '<a class="repo-name" href="' + detailUrl + '" target="_blank" rel="noopener">' + esc(repo.name) + '</a>' +
        '<a class="repo-gh" href="' + esc(repo.url) + '" target="_blank" rel="noopener" title="View on GitHub">' +
          '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>' +
        '</a>' +
      '</div>' +
      '<span class="repo-card-cat">' + (CATEGORY_ICONS[repo.category] || '') + ' ' + esc(repo.category) + '</span>' +
      dateLabel +
      '<p class="repo-desc">' + esc(repo.description) + '</p>' +
      '<div class="repo-tags">' + repo.tags.map(t =>
        '<button class="tag-pill' + (activeTags.has(t) ? ' active' : '') + '" data-tag="' + esc(t) + '" onclick="event.stopPropagation(); toggleTag(\'' + esc(t) + '\')">' + esc(t) + '</button>'
      ).join('') + '</div>' +
    '</div>';
  });
  html += '</div>';

  if (totalPages > 1) {
    html += '<div class="pagination">';
    html += '<button class="page-btn' + (currentPage === 1 ? ' disabled' : '') + '" onclick="goToPage(' + (currentPage - 1) + ')">&laquo; Prev</button>';
    const range = paginationRange(currentPage, totalPages);
    range.forEach(p => {
      if (p === '...') {
        html += '<span class="page-ellipsis">&hellip;</span>';
      } else {
        html += '<button class="page-btn' + (p === currentPage ? ' active' : '') + '" onclick="goToPage(' + p + ')">' + p + '</button>';
      }
    });
    html += '<button class="page-btn' + (currentPage === totalPages ? ' disabled' : '') + '" onclick="goToPage(' + (currentPage + 1) + ')">Next &raquo;</button>';
    html += '</div>';
  }

  area.innerHTML = html;
}

function paginationRange(current, total) {
  if (total <= 7) return Array.from({length: total}, (_, i) => i + 1);
  const pages = [];
  pages.push(1);
  if (current > 3) pages.push('...');
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push('...');
  pages.push(total);
  return pages;
}

window.goToPage = function(page) {
  const area = document.getElementById('repo-area');
  const totalFiltered = repos.filter(r => {
    if (activeCategory && r.category_slug !== activeCategory) return false;
    if (activeTags.size > 0 && ![...activeTags].some(t => r.tags.includes(t))) return false;
    if (searchQuery) {
      return r.name.toLowerCase().includes(searchQuery) ||
             r.description.toLowerCase().includes(searchQuery) ||
             r.tags.some(t => t.toLowerCase().includes(searchQuery)) ||
             r.category.toLowerCase().includes(searchQuery);
    }
    return true;
  }).length;
  const totalPages = Math.max(1, Math.ceil(totalFiltered / PAGE_SIZE));
  if (page < 1 || page > totalPages) return;
  currentPage = page;
  render();
  area.scrollIntoView({behavior: 'smooth', block: 'start'});
}

window.setSort = function(mode) {
  sortMode = mode;
  currentPage = 1;
  document.getElementById('sort-newest').classList.toggle('active', mode === 'newest');
  document.getElementById('sort-az').classList.toggle('active', mode === 'az');
  render();
}

window.toggleTag = function(tag) {
  if (activeTags.has(tag)) activeTags.delete(tag);
  else activeTags.add(tag);
  updateTagButtons();
  render();
  updateURL();
}

function esc(s) {
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

loadData();
</script>

</BaseLayout>
