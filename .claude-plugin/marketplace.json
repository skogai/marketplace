{
  "name": "skogai-market",
  "version": "0.0.4",
  "description": "skogai-market",
  "owner": {
    "name": "skogix",
    "url": "https://github.com/skogai"
  },
  "plugins": [
    {
      "name": "claude-docs",
      "source": "./claude-docs",
      "version": "0.0.1",
      "description": "download the latest claude code documentation and provide search functionality for it",
      "author": {
        "name": "Skogix",
        "email": "emil@skogsund.se",
        "url": "https://github.com/skogix"
      },
      "license": "MIT",
      "keywords": [
        "docs",
        "search",
        "claude-code"
      ],
      "commands": [
        "./commands/search.md"
      ],
      "agents": [
        "./agents/docs-researcher.md"
      ],
      "hooks": "./hooks/hooks.json"
    },
    {
      "name": "plugin-builder",
      "source": "./plugin-builder",
      "version": "0.0.2",
      "description": "plugin-builder",
      "author": {
        "name": "skogix",
        "email": "emil@skogsund.se",
        "url": "https://github.com/skogai"
      },
      "keywords": [
        "plugin",
        "builder",
        "development",
        "scaffolding",
        "example"
      ],
      "commands": [
        "./commands/init.md",
        "./commands/add.md",
        "./commands/edit.md",
        "./commands/validate.md",
        "./commands/publish.md"
      ],
      "skills": [
        "./skills/cc-skill-builder",
        "./skills/cc-command-builder",
        "./skills/cc-agent-builder",
        "./skills/cc-hook-builder",
        "./skills/cc-mcp-builder"
      ]
    }
  ]
}
