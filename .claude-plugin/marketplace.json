{
  "name": "skogai",
  "description": "Personal Claude Code plugin collection — git tools, workflow automation, and dev utilities",
  "owner": {
    "name": "skogix",
    "email": "emil@skogsund.se"
  },
  "metadata": {
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "skogai-tests",
      "version": "0.0.1",
      "description": "Bats testing skill and framework for shell script test-driven development",
      "source": "./plugins/skogai-tests",
      "strict": false
    },
    {
      "name": "skogai-core",
      "version": "0.0.1",
      "description": "the absolute core/basics",
      "source": "./plugins/skogai-core",
      "strict": false,
      "hooks": [
        {
          "event": "SessionStart",
          "script": "./plugins/skogai-core/hooks/session-start.sh"
        }
      ]
    },
    {
      "name": "skogai-plugin",
      "version": "0.0.1",
      "description": "skogai-plugin",
      "source": "./plugins/skogai-plugin",
      "strict": false
    },
    {
      "name": "skogai-jq",
      "version": "0.0.1",
      "description": "jq",
      "source": "./plugins/skogai-jq",
      "strict": false
    }
  ]
}
